# Copy this file to .env.local and fill in real values. Never commit .env.local.

# -----------------------------------------------------------------------------
# Microsoft Entra (Azure AD) / Microsoft Graph
# -----------------------------------------------------------------------------
# Application (client) ID from your Entra app registration.
AZURE_CLIENT_ID=your-client-id

# Directory (tenant) ID from your Entra app registration.
AZURE_TENANT_ID=your-tenant-id

# Client secret (for server-side or daemon flows). Keep secret; do not commit.
AZURE_CLIENT_SECRET=your-client-secret

# Set to "true" to enable Microsoft Graph calendar reads/writes (Phase 6/7).
# When false or unset, the app uses mock data.
MICROSOFT_GRAPH_ENABLED=false

# -----------------------------------------------------------------------------
# NextAuth (Phase 7: sign-in on booking page)
# -----------------------------------------------------------------------------
# Random string for signing session cookies. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Full URL of the app. Use http://localhost:3000 in dev; set to your domain in production.
# If Azure requires HTTPS for redirect URIs (e.g. when testing from your phone on LAN),
# use an HTTPS tunnel (e.g. ngrok: run "ngrok http 3000" and set NEXTAUTH_URL to the https URL).
NEXTAUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Optional: redirect and base URL for auth callbacks
# -----------------------------------------------------------------------------
# Full URL of the app (e.g. https://your-domain.com). Used to build redirect URIs.
# NEXT_PUBLIC_BASE_URL=https://localhost:3000

# Optional: canonical app URL for QR codes and links. If set, kiosk QR uses this
# instead of current origin (e.g. https://your-domain.com in production).
# NEXT_PUBLIC_APP_URL=https://your-domain.com
