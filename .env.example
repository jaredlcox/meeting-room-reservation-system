# Copy this file to .env.local and fill in real values. Never commit .env.local.

# -----------------------------------------------------------------------------
# Laravel API URL
# -----------------------------------------------------------------------------
# Base URL of the Laravel backend. The Next.js frontend sends all API requests here.
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Optional: canonical app URL for QR codes and links. If set, kiosk QR uses this
# instead of current origin.
# NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000
